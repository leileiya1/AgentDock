{
  "$defs": {
    "PlanStep": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "validation": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "title",
        "detail"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "plan_version": {
      "format": "int64",
      "minimum": 1,
      "type": "integer"
    },
    "risks": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "const": 1
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/PlanStep"
      },
      "type": "array"
    },
    "summary": {
      "maxLength": 4000,
      "minLength": 1,
      "type": "string"
    },
    "task_id": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "task_id",
    "plan_version",
    "summary",
    "steps",
    "risks"
  ],
  "title": "PlanResult",
  "type": "object"
}