{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentFlow",
  "version": "0.1.0",
  "identifier": "com.agentflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
